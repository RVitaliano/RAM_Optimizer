# Nome exibido na bandeja e na janela
APP_NAME=RAM Optimizer

# Percentual de RAM que dispara a otimização automática
RAM_THRESHOLD=88

# Intervalo de monitoramento em segundos
MONITOR_INTERVAL=60

# Processos de jogos que pausam a otimização automática
GAME_PROCESSES=Overwatch.exe,cs2.exe,valorant.exe,RainbowSix.exe,GTA5.exe,Cyberpunk2077.exe,eldenring.exe,FortniteClient-Win64-Shipping.exe,VALORANT.exe,LeagueOfLegends.exe